# Copy this file to .env and replace every placeholder with your real
# Firebase web app config from Firebase Console > Project settings > Your apps.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to true only when running Firebase emulators locally.
VITE_USE_FIREBASE_EMULATORS=

# Spark/free-tier projects must use "client".
# Use "functions" only after upgrading Firebase to Blaze and deploying functions.
VITE_EXAM_SECURITY_MODE=client

# Optional free-plan Google Sheets export.
# Create a Google OAuth web client and a target spreadsheet, then add both values.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_SHEET_ID=

# AI features (server-side only - NO VITE_ prefix, never sent to the browser).
# Get a free key at https://aistudio.google.com/apikey and paste it below.
# In production, set these in your Vercel project environment variables.
GEMINI_API_KEY=
# Optional model overrides (defaults: gemini-2.5-flash / text-embedding-004).
GEMINI_MODEL=
GEMINI_EMBED_MODEL=

# RAG study assistant (Upgrade 2) — server-side Firestore access for the
# ingest/query/generate functions. Paste your Firebase service account JSON as a
# single line (or base64-encoded). Same file used by scripts/import-questions.mjs.
# Download: Firebase Console > Project settings > Service accounts > Generate key.
FIREBASE_SERVICE_ACCOUNT=
