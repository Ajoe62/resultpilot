# Copy this file to .env and replace every placeholder with your real
# Firebase web app config from Firebase Console > Project settings > Your apps.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to true only when running Firebase emulators locally.
VITE_USE_FIREBASE_EMULATORS=

# Exam grading backend:
#   client    (default) — browser self-grades. Free, but scores are spoofable.
#   functions           — Firebase callables (requires Blaze).
#   vercel              — Vercel serverless graders (free on Spark, tamper-proof).
# CUTOVER to "vercel": (1) deploy the /api endpoints with FIREBASE_SERVICE_ACCOUNT,
# (2) set this to "vercel" and redeploy the frontend, (3) verify one real exam,
# (4) ONLY THEN change `results` create to `if false` in firestore.rules and
# deploy rules. Flipping the rule before step 3 breaks live submissions.
VITE_EXAM_SECURITY_MODE=client

# Multi-tenant tenant id. Set BOTH to the same value: your existing
# /schools/{id} document id (the school students register under). This is what
# the role-scoped queries and security-rule claims match on.
VITE_DEFAULT_SCHOOL_ID=
DEFAULT_SCHOOL_ID=

# Tutor invitations (server-side, optional). APP_ORIGIN is the base URL used to
# build invite links (e.g. https://resultpilot.app). Without RESEND_API_KEY the
# invite is still created and the link is returned for manual sharing.
APP_ORIGIN=
RESEND_API_KEY=
RESEND_FROM=

# Optional free-plan Google Sheets export.
# Create a Google OAuth web client and a target spreadsheet, then add both values.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_SHEET_ID=

# AI features (server-side only - NO VITE_ prefix, never sent to the browser).
# Get a free key at https://aistudio.google.com/apikey and paste it below.
# In production, set these in your Vercel project environment variables.
GEMINI_API_KEY=
# Optional model overrides (defaults: gemini-2.5-flash / gemini-embedding-001).
GEMINI_MODEL=
GEMINI_EMBED_MODEL=

# RAG study assistant (Upgrade 2) — server-side Firestore access for the
# ingest/query/generate functions. Paste your Firebase service account JSON as a
# single line (or base64-encoded). Same file used by scripts/import-questions.mjs.
# Download: Firebase Console > Project settings > Service accounts > Generate key.
FIREBASE_SERVICE_ACCOUNT=
