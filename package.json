{
  "name": "resultpilot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test tests/resultSheetData.test.mjs tests/sheetsExportData.test.mjs tests/termResultData.test.mjs",
    "test:rules": "npx firebase-tools emulators:exec --only firestore \"node --test tests/firestore.rules.test.mjs\"",
    "preview": "vite preview",
    "questions:import": "node scripts/import-questions.mjs",
    "firebase:deploy": "npx firebase-tools deploy --only firestore,hosting",
    "firebase:deploy:functions": "npx firebase-tools deploy --only functions",
    "firebase:emulators": "npx firebase-tools emulators:start --only auth,firestore,hosting",
    "firebase:emulators:functions": "npx firebase-tools emulators:start --only auth,functions,firestore,hosting"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.8.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "firebase-tools": "^15.15.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.19"
  }
}
