[debug] [2026-05-20T11:21:39.432Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/resultpilot-ddf7c/rulesets {"name":"projects/resultpilot-ddf7c/rulesets/bfc45b48-8aeb-41bb-899c-53b444a8e656","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return isSignedIn()\n        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));\n    }\n\n    match /admins/{adminId} {\n      allow read: if isSignedIn() && request.auth.uid == adminId;\n      allow write: if false;\n    }\n\n    match /schools/{schoolId} {\n      allow read: if isAdmin() || resource.data.isActive == true;\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /classes/{classId} {\n      allow read: if isAdmin() || resource.data.isActive == true;\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /students/{studentId} {\n      allow read: if isAdmin() || resource.data.isActive == true;\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /exams/{examId} {\n      allow read: if isAdmin() || resource.data.isActive == true;\n      allow create, update, delete: if isAdmin();\n\n      match /questions/{questionId} {\n        allow read: if isAdmin()\n          || get(/databases/$(database)/documents/exams/$(examId)).data.isActive == true;\n        allow create, update, delete: if isAdmin();\n      }\n    }\n\n    match /examSessions/{sessionId} {\n      allow read: if isAdmin();\n      allow create, update, delete: if false;\n    }\n\n    match /results/{resultId} {\n      allow create: if isValidClientResultCreate();\n      allow read, update, delete: if isAdmin();\n    }\n\n    function isValidClientResultCreate() {\n      let data = request.resource.data;\n\n      return request.auth == null\n        && data.keys().hasOnly([\n          \"studentName\",\n          \"studentId\",\n          \"admissionNumber\",\n          \"class\",\n          \"classId\",\n          \"school\",\n          \"schoolId\",\n          \"subject\",\n          \"academicSession\",\n          \"term\",\n          \"examId\",\n          \"examTitle\",\n          \"score\",\n          \"total\",\n          \"percentage\",\n          \"timeTaken\",\n          \"passed\",\n          \"answers\",\n          \"submittedAt\",\n          \"submittedAtMs\"\n        ])\n        && data.studentName is string\n        && data.studentName.size() >= 2\n        && data.studentName.size() <= 120\n        && data.studentId is string\n        && data.studentId.size() <= 80\n        && data.admissionNumber is string\n        && data.admissionNumber.size() <= 80\n        && data.class is string\n        && data.class.size() >= 1\n        && data.class.size() <= 40\n        && data.classId is string\n        && data.classId.size() >= 1\n        && data.classId.size() <= 80\n        && data.school is string\n        && data.school.size() >= 2\n        && data.school.size() <= 120\n        && data.schoolId is string\n        && data.schoolId.size() >= 1\n        && data.schoolId.size() <= 80\n        && data.subject is string\n        && data.subject.size() >= 1\n        && data.subject.size() <= 80\n        && data.academicSession is string\n        && data.academicSession.size() >= 1\n        && data.academicSession.size() <= 40\n        && data.term is string\n        && data.term.size() >= 1\n        && data.term.size() <= 40\n        && data.examId is string\n        && data.examId.size() > 0\n        && data.examTitle is string\n        && data.examTitle.size() >= 1\n        && data.examTitle.size() <= 120\n        && data.score is int\n        && data.total is int\n        && data.percentage is int\n        && data.timeTaken is int\n        && data.passed is bool\n        && data.score >= 0\n        && data.total >= 1\n        && data.total <= 300\n        && data.score <= data.total\n        && data.percentage >= 0\n        && data.percentage <= 100\n        && data.timeTaken >= 0\n        && data.timeTaken <= 10800\n        && data.answers is list\n        && data.answers.size() == data.total\n        && data.submittedAt == request.time\n        && data.submittedAtMs is int;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-20T11:21:40.010511Z","metadata":{"services":["cloud.firestore"]}}
